<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F0F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔗 URL Checker"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2D2020"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste any URL or SMS text below"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="6dp"/>

        <!-- Input Box -->
        <EditText
            android:id="@+id/inputText"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:hint="Paste URL or message here..."
            android:textSize="15sp"
            android:textColor="#2D2020"
            android:background="@drawable/card_purple"
            android:padding="16dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="24dp"/>

        <!-- Scan Button -->
        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔍 Scan Now"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#F4A0A0"
            android:textColor="#2D2020"
            android:layout_marginTop="16dp"/>

        <!-- Result Card -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_red"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <!-- Risk Badge -->
            <TextView
                android:id="@+id/riskBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 HIGH RISK"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2D2020"/>

            <!-- Score -->
            <TextView
                android:id="@+id/riskScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk Score: 0/100"
                android:textSize="16sp"
                android:textColor="#2D2020"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- XAI Reasons Card -->
        <LinearLayout
            android:id="@+id/xaiCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_orange"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Why AI flagged this:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D2020"/>

            <TextView
                android:id="@+id/reasonsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#2D2020"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"/>

        </LinearLayout>

        <!-- Safe Result Card -->
        <LinearLayout
            android:id="@+id/safeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_green"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Looks Safe!"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2D2020"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No suspicious patterns detected."
                android:textSize="14sp"
                android:textColor="#2D2020"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Clear Button -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Clear"
            android:textSize="14sp"
            android:backgroundTint="#B8B8E8"
            android:textColor="#2D2020"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>